# --- Required (per workspace) ---
# Your workspace slug (Settings -> Headless in the cmssy dashboard)
CMSSY_WORKSPACE_SLUG=
# Secret that unlocks draft / preview mode (Settings -> Headless)
CMSSY_DRAFT_SECRET=

# --- Optional ---
# apiUrl + editorOrigin default to cmssy cloud; set them only for
# local dev against a local backend or a self-hosted admin:
# CMSSY_API_URL=http://localhost:4000/graphql   # default: https://api.cmssy.io/graphql
# CMSSY_EDITOR_ORIGIN=http://localhost:3001     # default: https://www.cmssy.io
